//Матричная Клавиатура + вывод на дисплей (ПЕЧАТНАЯ МАШИНКА)
#include <Keypad.h> //библиотека для матричной клавиатуры
#include <LiquidCrystal_I2C.h> // библиотека для l2c дисплея
#include <Wire.h>

// ========== НАСТРОЙКА LCD ==========
LiquidCrystal_I2C lcd(0x20, 16, 2);

// ========== НАСТРОЙКА КЛАВИАТУРЫ ==========
const byte ROWS = 4; //количество рядов, строк
const byte COLS = 4; //количетсво столбцов

char keys[ROWS][COLS] = {
  {'1','2','3','A'}, // строка 0 (физический ряд 1)
  {'4','5','6','B'}, // строка 1 (физический ряд 2)
  {'7','8','9','C'}, // строка 2 (физический ряд 3)
  {'*','0','#','D'} // строка 3 (физический ряд 4)
};

byte rowPins[ROWS] = {9, 8, 7, 6}; // какие пины подключены на ардуино!
byte colPins[COLS] = {5, 4, 3, 2}; // какие пины подключены на ардуино!

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS); // создаём клавиатуру, присваиваем имя и пины

// ========== ПЕРЕМЕННЫЕ ==========
String textLine = "";     // строка, которую набираем
int cursorPos = 0;        // позиция курсора

void setup() {
lcd.init();               // Включить дисплей (проснулся!)
lcd.backlight();          // Зажечь подсветку (чтобы было видно)
lcd.clear();              // Очистить экран (на всякий случай, убрать мусор)
lcd.setCursor(0, 0);      // Поставить курсор в начало (0-й символ, 0-я строка)
lcd.print("Type:");       // Напечатать текст "Type:"
}

void loop() {
  char key = keypad.getKey(); // берёт значения из созданный нами выше keypad
  
  if (key != NO_KEY) {
    
    // === ОБРАБОТКА СПЕЦКЛАВИШ ===
    
    if (key == '*') {          // * - очистить всё
      textLine = "";
      cursorPos = 0;
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Type:");
    }
    else if (key == '#') {     // # - пробел
      textLine += " ";
      cursorPos++;
    }
    else {                     // обычные символы
      textLine += key;
      cursorPos++;
    }
    
    // === ВЫВОД НА LCD ===
    
    lcd.setCursor(0, 1);               // курсор на вторую строку
    lcd.print("                ");      // очищаем вторую строку (16 пробелов)
    lcd.setCursor(0, 1);
    
    // Если текст помещается на одной строке (до 16 символов)
    if (textLine.length() <= 16) {
      lcd.print(textLine);
    }
    else {
      // Показываем последние 16 символов (как бегущая строка)
      String displayText = textLine.substring(textLine.length() - 16);
      lcd.print(displayText);
    }
    
    // Маленькая задержка от дребезга
    delay(150);
  }
}
